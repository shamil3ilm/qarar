APP_NAME="ERP System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost
FRONTEND_URL=http://localhost:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

#--------------------------------------------------------------------------
# Logging
#--------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

#--------------------------------------------------------------------------
# Database
#--------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=erp
DB_USERNAME=root
DB_PASSWORD=

# Read/Write DB Separation (optional — point DB_READ_HOST to a MySQL replica)
# Leave unset to use DB_HOST for both reads and writes (single-server default)
#DB_READ_HOST="${DB_HOST}"
#DB_WRITE_HOST="${DB_HOST}"

#--------------------------------------------------------------------------
# JWT Authentication
#--------------------------------------------------------------------------
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160
JWT_BLACKLIST_ENABLED=true
JWT_BLACKLIST_GRACE_PERIOD=0

#--------------------------------------------------------------------------
# Session & Cache
#--------------------------------------------------------------------------
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=redis
CACHE_PREFIX=erp_

#--------------------------------------------------------------------------
# Queue & Broadcasting
#--------------------------------------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

#--------------------------------------------------------------------------
# Redis
# Redis is required for production caching and queues.
# For local dev without Redis, fall back with: CACHE_STORE=array QUEUE_CONNECTION=database
#--------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

#--------------------------------------------------------------------------
# Circuit Breaker (external API fault tolerance)
#--------------------------------------------------------------------------
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_OPEN_TTL=60
CIRCUIT_BREAKER_COUNTER_TTL=120

#--------------------------------------------------------------------------
# Mail
#--------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

#--------------------------------------------------------------------------
# CORS (Comma-separated list of allowed origins for production)
#--------------------------------------------------------------------------
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

#--------------------------------------------------------------------------
# ZATCA Integration (Saudi Arabia e-Invoicing Compliance)
#--------------------------------------------------------------------------
ZATCA_INTEGRATION_ENABLED=true
ZATCA_INTEGRATION_URL=http://localhost:8001/api/v1
ZATCA_INTEGRATION_API_KEY=
ZATCA_INTEGRATION_WEBHOOK_SECRET=
ZATCA_INTEGRATION_TIMEOUT=30
ZATCA_RETRY_TIMES=3
ZATCA_RETRY_SLEEP=1000

#--------------------------------------------------------------------------
# ERP Defaults
#--------------------------------------------------------------------------
ERP_DEFAULT_CURRENCY=SAR
ERP_DEFAULT_TIMEZONE=Asia/Riyadh
ERP_DEFAULT_LANGUAGE=en

# Invoice async document generation (queue: documents)
ERP_INVOICE_AUTO_PDF=true
ERP_INVOICE_SEND_EMAIL=false

# Default chart-of-account IDs (set to integer IDs from your accounts table)
ERP_ACCOUNT_RECEIVABLE=
ERP_ACCOUNT_PAYABLE=
ERP_ACCOUNT_SALES=
ERP_ACCOUNT_EXPENSE=
ERP_ACCOUNT_CASH=
ERP_ACCOUNT_TAX_PAYABLE=
ERP_ACCOUNT_TAX_RECEIVABLE=
ERP_ACCOUNT_SALARY_EXPENSE=
ERP_ACCOUNT_SALARY_PAYABLE=
ERP_ACCOUNT_WIP_INVENTORY=
ERP_ACCOUNT_FG_INVENTORY=
ERP_ACCOUNT_RM_INVENTORY=

# Statutory deduction account IDs
ERP_STATUTORY_GOSI_EE=
ERP_STATUTORY_GOSI_ER=
ERP_STATUTORY_PF_EE=
ERP_STATUTORY_PF_ER=
ERP_STATUTORY_ESI_EE=
ERP_STATUTORY_ESI_ER=

#--------------------------------------------------------------------------
# Security Settings
#--------------------------------------------------------------------------
# Maximum login attempts before lockout
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Password requirements (applied via Password::defaults())
PASSWORD_MIN_LENGTH=8

#--------------------------------------------------------------------------
# SMS
#--------------------------------------------------------------------------
SMS_DRIVER=log
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_SMS_FROM=ERP
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

#--------------------------------------------------------------------------
# Laravel Telescope (dev monitoring — disable in production)
#--------------------------------------------------------------------------
TELESCOPE_ENABLED=true
# Comma-separated emails allowed to access Telescope in non-local environments
TELESCOPE_ALLOWED_EMAILS=

#--------------------------------------------------------------------------
# Performance
#--------------------------------------------------------------------------
SLOW_QUERY_THRESHOLD_MS=500
RESPONSE_BUDGET_MS=300

